{
    "id": "com.markopejic.downloader",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "base": "io.qt.PySide.BaseApp",
    "base-version": "6.10",
    "command": "media-downloader",
    "finish-args": [
        "--share=network",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--share=ipc",
        "--device=dri",
        "--filesystem=xdg-download"
    ],
    "cleanup" : [
        "/share/bash-completion",
        "/share/doc",
        "/share/fish",
        "/share/man",
        "/share/zsh"
    ],
    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh",
        "python3 -m compileall --invalidation-mode=unchecked-hash /app"
    ],
    "build-options": {
        "env": [
            "BASEAPP_REMOVE_WEBENGINE=1",
            "BASEAPP_DISABLE_NUMPY=1"
        ]
    },
    "modules": [
        "python3-yt-dlp.json",
        {
            "name": "com.markopejic.downloader",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm644 resources/linux/${FLATPAK_ID}.desktop -t $FLATPAK_DEST/share/applications/",
                "install -Dm644 resources/linux/${FLATPAK_ID}.metainfo.xml -t $FLATPAK_DEST/share/metainfo/",
                "install -Dm644 resources/icon.svg $FLATPAK_DEST/share/icons/hicolor/scalable/apps/${FLATPAK_ID}.svg",
                "install -Dm644 resources/icon.png $FLATPAK_DEST/share/icons/hicolor/512x512/apps/${FLATPAK_ID}.png",
                "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} --compile . --no-build-isolation"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/markop404/media-downloader/",
                    "commit": "334b696bb5951ee29da677511efeef01b017934e"
                }
            ]
        }
    ]
}
